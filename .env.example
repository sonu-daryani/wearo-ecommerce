# MongoDB (Atlas) — replace USER, PASSWORD, cluster host, and DB name
# Atlas → Network Access: allow 0.0.0.0/0 (or Vercel) so production can connect
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority"
# Prisma CLI (db push, migrate) requires DATABASE_URL. Node scripts also accept mongodb_uri via scripts/load-env.cjs.

# NextAuth — generate: openssl rand -base64 32
# Required on Vercel (same value as local or a new secret for prod)
AUTH_SECRET=""

# Canonical site URL — NO trailing slash
# Local: http://localhost:3000
# Vercel: https://wearo-ecommerce.vercel.app
AUTH_URL="http://localhost:3000"

# Optional: public site URL for Open Graph / canonical URLs (no trailing slash)
# NEXT_PUBLIC_SITE_URL="https://wearo-ecommerce.vercel.app"

# Optional on Vercel if AUTH_URL is unset (Auth.js can infer from VERCEL_URL)
# AUTH_TRUST_HOST="true"

# Google OAuth — Web application client in Google Cloud Console
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Google Cloud Console (Credentials → OAuth 2.0 Client ID) ---
#
# Authorized JavaScript origins (one per line):
#   http://localhost:3000
#   https://wearo-ecommerce.vercel.app
#
# Authorized redirect URIs — MUST be exact (NOT the homepage URL):
#   http://localhost:3000/api/auth/callback/google
#   https://wearo-ecommerce.vercel.app/api/auth/callback/google
#
# Wrong: https://wearo-ecommerce.vercel.app/  ← will cause errors

# --- Admin app (separate Next.js repo: wearo-admin, default port 3001) ---
# Shown to staff on /account as "Admin portal"
NEXT_PUBLIC_ADMIN_PORTAL_URL="http://localhost:3001"
# Optional: reverse-proxy admin UI through storefront at /__/admin/* (see next.config.mjs)
# ADMIN_APP_ORIGIN="http://localhost:3001"

# Public JSON for company name, logo, currency, payment flags (from DB; see wearo-admin → Company settings):
# GET /api/company-settings
#
# --- Payments (Stripe / Razorpay / Cashfree) ---
# API secrets are stored in MongoDB from Admin → Payment settings (server-only; not in .env).
#
# Cashfree sandbox vs production API + JS SDK (merchant secret is in DB, not here):
# CASHFREE_ENV="sandbox"
# CASHFREE_ENV="production"
#
# Checkout APIs: POST /api/payments/session, POST /api/payments/verify

# --- Hide backend URL in the browser: same-origin API proxy ---
# Storefront calls fetch("/api/proxy/crm/orders") → server forwards to BACKEND_PROXY_TARGET/crm/orders
# BACKEND_PROXY_TARGET="https://your-internal-api.example.com"
# Optional shared secret your API validates (header x-wearo-proxy-secret)
# BACKEND_PROXY_SECRET=""

# --- Cloudflare R2 — configure on wearo-admin for staff uploads (storefront can omit if unused) ---
#
# 1) Dashboard → R2 → your bucket (e.g. wearo-india) → ensure the token is scoped to that bucket
#    (read + write + list is enough for uploads).
# 2) R2 → Overview → copy "S3 API" endpoint → R2_ENDPOINT (no bucket name in the URL).
# 3) R2 → Manage R2 API Tokens → Create API token (or User token) with read/write/list on
#    bucket wearo-india → after create, copy:
#      Access Key ID     → R2_ACCESS_KEY_ID
#      Secret Access Key → R2_SECRET_ACCESS_KEY  (shown once; rotate if leaked)
# 4) Public URLs for browsers: R2 → wearo-india → Settings → Public access
#    Enable R2.dev subdomain (or attach a custom domain). Copy the public URL origin only:
#      https://pub-<your-subdomain>.r2.dev   OR   https://cdn.yourdomain.com
#    Set that as R2_PUBLIC_BASE_URL with NO trailing slash. This is NOT the same as R2_ENDPOINT.
#    next.config.mjs uses R2_PUBLIC_BASE_URL at build time for next/image remotePatterns on Vercel.
#
R2_ENDPOINT="https://3670b69a1642374d420463d95953d794.r2.cloudflarestorage.com"
R2_BUCKET="wearo-india"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BASE_URL=""

# Upload catalog images from public/images to R2 and upsert product srcUrl/gallery:
# npm run upload:r2-catalog
# Upload hero + dress-style images to R2 and upsert CmsSiteAsset (homepage CMS):
# npm run upload:r2-site
# (scripts use load-env.cjs; Prisma CLI still needs DATABASE_URL in .env for db push)
