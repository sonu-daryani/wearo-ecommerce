# MongoDB (Atlas) — replace USER, PASSWORD, cluster host, and DB name
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET=""

# App URL (production: your real domain)
AUTH_URL="http://localhost:3000"

# Google OAuth — create OAuth client in Google Cloud Console (Web application)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
